# .gitignore
# =============================================================================
# GoClaw Deployment — các file KHÔNG được commit lên Git
# =============================================================================

# ── Secrets & Environment ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.secret
secrets/

# ── SSH Keys ──────────────────────────────────────────────────────────────────
*.pem
*.key
id_rsa*
id_ed25519*
deploy_key*

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Docker ────────────────────────────────────────────────────────────────────
# docker-compose.override.yml đã được commit có chủ đích — KHÔNG gitignore nó

# ── OS & Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ── Temp ──────────────────────────────────────────────────────────────────────
tmp/
temp/
.tmp/
